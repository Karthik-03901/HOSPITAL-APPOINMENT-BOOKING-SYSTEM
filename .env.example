# ==============================================
# MediQueue Environment Variables Template
# ==============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to git!

# ==============================================
# SUPABASE CONFIGURATION
# ==============================================
# Get these from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ==============================================
# RAZORPAY PAYMENT GATEWAY
# ==============================================
# Get these from: https://dashboard.razorpay.com/app/keys

# Test Mode Keys (for development)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxx

# Live Mode Keys (for production - uncomment when ready)
# RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx
# RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxx

# ==============================================
# VITE ENVIRONMENT VARIABLES
# ==============================================
# If using Vite, prefix with VITE_
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx

# ==============================================
# NVIDIA AI CHATBOT (Dr.Chat)
# ==============================================
# Get API key from: https://build.nvidia.com
# Current key (for testing - replace for production):
NVIDIA_API_KEY=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

# Note: For security, move this to server-side in production!
# The AI chatbot (Dr.Chat) uses NVIDIA NeMo Megatron API
# Model: meta/llama-3.1-8b-instruct
# Endpoint: https://integrate.api.nvidia.com/v1/chat/completions

# ==============================================
# APPLICATION SETTINGS (Optional)
# ==============================================
# APP_NAME=MediQueue
# APP_ENV=development
# APP_DEBUG=true

# ==============================================
# NOTES
# ==============================================
# 1. Create a copy of this file named .env
# 2. Replace all placeholders with actual values
# 3. Never commit .env to version control
# 4. Add .env to .gitignore
# 5. Use test keys in development
# 6. Use live keys only in production
# 7. Keep secrets secure!

# ==============================================
# QUICK LINKS
# ==============================================
